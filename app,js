const state = {
  rows: [],
  filteredRows: [],
  selected: null,
};

const els = {
  backendUrl: document.getElementById("backendUrl"),
  windowSelect: document.getElementById("windowSelect"),
  minScore: document.getElementById("minScore"),
  minDrop: document.getElementById("minDrop"),
  search: document.getElementById("search"),
  refreshBtn: document.getElementById("refreshBtn"),
  feedBody: document.getElementById("feedBody"),
  rowsKpi: document.getElementById("rowsKpi"),
  whalesKpi: document.getElementById("whalesKpi"),
  scoreKpi: document.getElementById("scoreKpi"),
  refreshKpi: document.getElementById("refreshKpi"),
  detailsTitle: document.getElementById("detailsTitle"),
  detailsMeta: document.getElementById("detailsMeta"),
  metaCurrent: document.getElementById("metaCurrent"),
  metaScore: document.getElementById("metaScore"),
  metaWindow: document.getElementById("metaWindow"),
  metaWhale: document.getElementById("metaWhale"),
  bids: document.getElementById("bids"),
  asks: document.getElementById("asks"),
  tradesList: document.getElementById("tradesList"),
  historyBody: document.getElementById("historyBody"),
  detailChart: document.getElementById("detailChart"),
};

els.refreshBtn.addEventListener("click", loadFeed);
els.windowSelect.addEventListener("change", loadFeed);
els.minScore.addEventListener("input", renderFeed);
els.minDrop.addEventListener("input", renderFeed);
els.search.addEventListener("input", renderFeed);

async function loadFeed() {
  const base = els.backendUrl.value.trim().replace(/\/$/, "");
  const windowValue = els.windowSelect.value;

  if (!base.startsWith("http")) {
    els.feedBody.innerHTML = `<tr><td colspan="10" class="bad">Invalid backend URL</td></tr>`;
    return;
  }

  const url = `${base}/api/markets?window=${encodeURIComponent(windowValue)}&limit=200`;
  els.feedBody.innerHTML = `<tr><td colspan="10" class="empty">Loading…</td></tr>`;

  try {
    const response = await fetch(url);
    const payload = await response.json();

    if (!response.ok) {
      throw new Error(payload.error || "Failed to load feed");
    }

    state.rows = Array.isArray(payload.data) ? payload.data : [];
    renderFeed();
    updateStats();

    if (state.filteredRows.length) {
      await selectRow(state.filteredRows[0]);
    } else {
      clearDetails();
    }
  } catch (error) {
    els.feedBody.innerHTML = `<tr><td colspan="10" class="bad">${escapeHtml(error.message)}</td></tr>`;
    clearDetails();
  }
}

function renderFeed() {
  const minScore = Number(els.minScore.value || 0);
  const minDrop = Number(els.minDrop.value || 0);
  const search = els.search.value.trim().toLowerCase();

  state.filteredRows = state.rows.filter((row) => {
    const text = `${row.title || ""} ${row.outcome || ""} ${row.category || ""}`.toLowerCase();
    return (
      num(row.signal?.score) >= minScore &&
      num(row.analysis?.windowDropPct) >= minDrop &&
      (!search || text.includes(search))
    );
  });

  if (!state.filteredRows.length) {
    els.feedBody.innerHTML = `<tr><td colspan="10" class="empty">No rows found</td></tr>`;
    els.rowsKpi.textContent = "0";
    return;
  }

  els.feedBody.innerHTML = state.filteredRows
    .map((row) => {
      const flow = (row.trades || [])
        .slice(0, 3)
        .map((trade) => `${trade.side === "BUY" ? "B" : "S"} ${trade.label || shortWallet(trade.proxyWallet)}`)
        .join(" · ");

      return `
        <tr data-condition="${escapeHtml(row.conditionId)}" data-token="${escapeHtml(row.tokenId)}">
          <td class="market-cell">
            <div class="market-title">${escapeHtml(row.title || "-")}</div>
            <div class="muted">${escapeHtml(row.outcome || "-")} · ${escapeHtml(row.category || "market")}</div>
          </td>
          <td>${fmtProb(row.currentPrice)}</td>
          <td class="bad">-${num(row.analysis?.tickDropPct).toFixed(2)}%</td>
          <td class="bad">-${num(row.analysis?.windowDropPct).toFixed(2)}%</td>
          <td class="bad">-${num(row.analysis?.openingDropPct).toFixed(2)}%</td>
          <td class="bad">-${num(row.analysis?.peakToCurrentPct).toFixed(2)}%</td>
          <td class="${scoreClass(num(row.signal?.score))}">${num(row.signal?.score)} ${escapeHtml(row.signal?.label || "")}</td>
          <td><span class="badge">${escapeHtml(row.signal?.type || "-")}</span></td>
          <td class="whale">${row.whale?.whaleFlag ? `${escapeHtml(row.whale.whaleType)} ${num(row.whale.whaleScore)}` : "-"}</td>
          <td class="muted">${escapeHtml(flow || "-")}</td>
        </tr>
      `;
    })
    .join("");

  [...els.feedBody.querySelectorAll("tr")].forEach((tr) => {
    tr.addEventListener("click", () => {
      const row = state.filteredRows.find(
        (item) => item.conditionId === tr.dataset.condition && item.tokenId === tr.dataset.token
      );
      if (row) selectRow(row);
    });
  });

  els.rowsKpi.textContent = String(state.filteredRows.length);
}

async function selectRow(row) {
  state.selected = row;

  els.detailsTitle.textContent = row.title || "Selected market";
  els.detailsMeta.textContent = `${row.outcome || "-"} · ${row.category || "market"}`;
  els.metaCurrent.textContent = fmtProb(row.currentPrice);
  els.metaScore.textContent = `${num(row.signal?.score)} ${row.signal?.label || ""}`;
  els.metaWindow.textContent = `-${num(row.analysis?.windowDropPct).toFixed(2)}%`;
  els.metaWhale.textContent = row.whale?.whaleFlag
    ? `${row.whale.whaleType} ${num(row.whale.whaleScore)}`
    : "none";

  renderOrderBook(row.orderbook || {});
  renderTrades(row.trades || []);
  renderHistory(row.trades || []);
  drawChart(row.chart || [], row.analysis || null);

  try {
    const base = els.backendUrl.value.trim().replace(/\/$/, "");
    const url = `${base}/api/market/${encodeURIComponent(row.conditionId)}/details?tokenId=${encodeURIComponent(row.tokenId)}`;
    const response = await fetch(url);
    const payload = await response.json();

    if (!response.ok) {
      throw new Error(payload.error || "Failed to load details");
    }

    renderOrderBook(payload.orderbook || {});
    renderTrades(payload.trades || []);
    renderHistory(payload.trades || []);
    drawChart(payload.chart || [], payload.analysis || null);

    if (payload.analysis) {
      els.metaCurrent.textContent = fmtProb(payload.analysis.currentPrice || row.currentPrice);
      els.metaWindow.textContent = `-${num(payload.analysis.windowDropPct).toFixed(2)}%`;
    }

    if (payload.whale) {
      els.metaWhale.textContent = payload.whale.whaleFlag
        ? `${payload.whale.whaleType} ${num(payload.whale.whaleScore)}`
        : "none";
    }
  } catch {}
}

function clearDetails() {
  els.detailsTitle.textContent = "Select a market";
  els.detailsMeta.textContent = "-";
  els.metaCurrent.textContent = "-";
  els.metaScore.textContent = "-";
  els.metaWindow.textContent = "-";
  els.metaWhale.textContent = "-";
  els.bids.innerHTML = `<div class="empty">No bids</div>`;
  els.asks.innerHTML = `<div class="empty">No asks</div>`;
  els.tradesList.innerHTML = `<div class="empty">No trades</div>`;
  els.historyBody.innerHTML = `<tr><td colspan="5" class="empty">No market development</td></tr>`;
  drawChart([], null);
}

function renderOrderBook(book = {}) {
  els.bids.innerHTML = (book.bids || []).length
    ? book.bids.map(levelTemplate).join("")
    : `<div class="empty">No bids</div>`;

  els.asks.innerHTML = (book.asks || []).length
    ? book.asks.map(levelTemplate).join("")
    : `<div class="empty">No asks</div>`;
}

function levelTemplate(level) {
  return `<div class="level"><span>${fmtProb(level.price)}</span><span>${fmtUsd(level.size)}</span></div>`;
}

function renderTrades(trades = []) {
  els.tradesList.innerHTML = trades.length
    ? trades.slice(0, 14).map((trade) => `
      <div class="trade-row mono">
        <span class="${trade.side === "BUY" ? "good" : "bad"}">${escapeHtml(trade.side || "-")}</span>
        <span>${timeOnly(trade.timestamp)}</span>
        <span>${escapeHtml(trade.label || shortWallet(trade.proxyWallet))}</span>
        <span>${fmtProb(trade.price)}</span>
        <span>${fmtUsd(trade.size)}</span>
      </div>
    `).join("")
    : `<div class="empty">No trades</div>`;
}

function renderHistory(trades = []) {
  if (!trades.length) {
    els.historyBody.innerHTML = `<tr><td colspan="5" class="empty">No market development</td></tr>`;
    return;
  }

  els.historyBody.innerHTML = trades.slice(0, 40).map((trade) => `
    <tr>
      <td>${timeOnly(trade.timestamp)}</td>
      <td>${fmtProb(trade.price)}</td>
      <td>${fmtUsd(trade.size)}</td>
      <td class="${trade.side === "BUY" ? "good" : "bad"}">${escapeHtml(trade.side || "-")}</td>
      <td>${escapeHtml(trade.label || shortWallet(trade.proxyWallet))}</td>
    </tr>
  `).join("");
}

function drawChart(chart = [], analysis = null) {
  const canvas = els.detailChart;
  const ctx = canvas.getContext("2d");
  const width = canvas.width;
  const height = canvas.height;

  ctx.clearRect(0, 0, width, height);
  ctx.fillStyle = "#061019";
  ctx.fillRect(0, 0, width, height);

  if (!Array.isArray(chart) || chart.length < 2) return;

  const points = chart
    .map((point) => ({
      x: Number(point.t ?? point.timestamp ?? 0),
      y: Number(point.p ?? point.price ?? 0),
    }))
    .filter((p) => Number.isFinite(p.x) && Number.isFinite(p.y) && p.x > 0);

  if (points.length < 2) return;

  const minX = Math.min(...points.map((p) => p.x));
  const maxX = Math.max(...points.map((p) => p.x));
  const minY = Math.min(...points.map((p) => p.y));
  const maxY = Math.max(...points.map((p) => p.y));

  const pad = 16;
  const px = (x) => pad + ((x - minX) / Math.max(1, maxX - minX)) * (width - pad * 2);
  const py = (y) => height - pad - ((y - minY) / Math.max(0.0001, maxY - minY)) * (height - pad * 2);

  ctx.strokeStyle = "#14314a";
  ctx.lineWidth = 1;

  for (let i = 0; i < 4; i++) {
    const y = pad + ((height - pad * 2) / 4) * i;
    ctx.beginPath();
    ctx.moveTo(pad, y);
    ctx.lineTo(width - pad, y);
    ctx.stroke();
  }

  ctx.strokeStyle = "#63b5ff";
  ctx.lineWidth = 2;
  ctx.beginPath();

  points.forEach((point, index) => {
    const x = px(point.x);
    const y = py(point.y);
    if (index === 0) ctx.moveTo(x, y);
    else ctx.lineTo(x, y);
  });

  ctx.stroke();

  if (analysis?.localHighTs && Number.isFinite(analysis.localHighPrice)) {
    dot(ctx, px(analysis.localHighTs), py(analysis.localHighPrice), "#ffd76c");
  }

  if (analysis?.localLowTs && Number.isFinite(analysis.localLowPrice)) {
    dot(ctx, px(analysis.localLowTs), py(analysis.localLowPrice), "#ff7f7f");
  }

  const last = points[points.length - 1];
  dot(ctx, px(last.x), py(last.y), "#82f3b7");
}

function dot(ctx, x, y, color) {
  ctx.fillStyle = color;
  ctx.beginPath();
  ctx.arc(x, y, 4, 0, Math.PI * 2);
  ctx.fill();
}

function updateStats() {
  const rows = state.rows;
  const whales = rows.filter((row) => row.whale?.whaleFlag).length;
  const avgScore = rows.length
    ? rows.reduce((sum, row) => sum + num(row.signal?.score), 0) / rows.length
    : 0;

  els.whalesKpi.textContent = String(whales);
  els.scoreKpi.textContent = avgScore.toFixed(1);
  els.refreshKpi.textContent = new Date().toLocaleTimeString();
}

function fmtProb(value) {
  return `${(num(value) * 100).toFixed(1)}%`;
}

function fmtUsd(value) {
  return `$${num(value).toLocaleString(undefined, { maximumFractionDigits: 0 })}`;
}

function shortWallet(address = "") {
  return address ? `${address.slice(0, 6)}…${address.slice(-4)}` : "unknown";
}

function timeOnly(ts) {
  return ts ? new Date(Number(ts)).toLocaleTimeString() : "-";
}

function scoreClass(score) {
  if (score >= 65) return "score-a";
  if (score >= 45) return "score-b";
  return "score-c";
}

function num(value) {
  return Number(value || 0);
}

function escapeHtml(value) {
  return String(value || "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

loadFeed();
setInterval(loadFeed, 30000);
